# Load secretspec-managed secrets into the session. Checks a
# project-local secretspec.toml first, then falls back to the one in
# $HOME (the common "secrets-scoped-to-the-user, not-the-repo"
# layout).
#
# Requires:
#   - secretspec (https://secretspec.dev): `brew install secretspec`
#     or pull a build from the project's release page.
#   - direnv: `brew install direnv` + shell hook + `direnv allow`
#     once in this checkout.
#
# secretspec reads from the OS keychain (macOS Keychain / Linux
# secret-service); nothing here touches plaintext on disk. See
# docs/development.md for token management + rotation.
if command -v secretspec >/dev/null 2>&1; then
  # Pick the first existing secretspec.toml and source ONLY the
  # named vars (grep-filter) so unrelated env from `secretspec run`
  # does not pollute this session.
  for candidate in "${PWD}/secretspec.toml" "${HOME}/secretspec.toml"; do
    if [ -f "${candidate}" ]; then
      eval "$(secretspec -f "${candidate}" run -- env 2>/dev/null | grep -E '^(CARGO_REGISTRY_TOKEN|GITLAB_TOKEN|JIRA_USERNAME|JIRA_API_TOKEN)=' | sed 's/^/export /')" || true
      break
    fi
  done
fi
